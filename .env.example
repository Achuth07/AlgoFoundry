# AlgoFoundry environment.
# Copy to .env and edit. Most runtime settings live in the web GUI (stored in SQLite);
# these are only the bootstrap values used on first launch.

# Web GUI / server
ALGOFOUNDRY_HOST=127.0.0.1
ALGOFOUNDRY_PORT=8000

# Login for the GUI (change these!)
ALGOFOUNDRY_USER=admin
ALGOFOUNDRY_PASSWORD=change-me-now

# Shared secret that TradingView must include in every webhook payload.
# If left blank, a random one is generated on first run (see the GUI > Settings).
ALGOFOUNDRY_WEBHOOK_SECRET=

# SQLite database location
ALGOFOUNDRY_DB=algofoundry.db
