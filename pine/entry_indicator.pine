//@version=5
// AlgoFoundry — ENTRY indicator (unfiltered ATR trailing-stop flip to long).
// Ported from your v4 "JL ATR + Volume Spikes" script. Entry stays UNFILTERED
// as requested: BUY fires purely when the ATR trailing stop flips to long.
//
// Alert: create one alert on this indicator, condition = "Any alert() function
// call", and set it to fire ONCE PER BAR CLOSE. The alert() messages below are
// gated by barstate.isconfirmed so they only emit on the closed bar.
indicator(title="AlgoFoundry Entry — ATR + Volume", overlay=true)

// === INPUTS ===
atrPeriod    = input.int(20, "ATR Period")
atrMultiplier = input.float(4.0, "ATR Multiplier", minval=0.5, maxval=1000, step=0.1)
vol_length   = input.int(20, "Volume SMA length", minval=1)
smoothLen    = input.int(20, "VWMA Smooth", minval=1)
src          = input.source(close, "Source")

// --- Webhook payload ---
webhookSecret = input.string("PASTE_YOUR_SECRET_HERE", "Webhook secret")

// === ATR TRAILING STOP ===
atr = ta.atr(atrPeriod)
nLoss = atrMultiplier * atr
var float xATRTrailingStop = na
xATRTrailingStop := if (close > nz(xATRTrailingStop[1], 0) and close[1] > nz(xATRTrailingStop[1], 0))
    math.max(nz(xATRTrailingStop[1]), close - nLoss)
else if (close < nz(xATRTrailingStop[1], 0) and close[1] < nz(xATRTrailingStop[1], 0))
    math.min(nz(xATRTrailingStop[1]), close + nLoss)
else if (close > nz(xATRTrailingStop[1], 0))
    close - nLoss
else
    close + nLoss

var int pos = 0
pos := if (close[1] < nz(xATRTrailingStop[1], 0) and close > nz(xATRTrailingStop[1], 0))
    1
else if (close[1] > nz(xATRTrailingStop[1], 0) and close < nz(xATRTrailingStop[1], 0))
    -1
else
    nz(pos[1], 0)

// === SIGNAL STATE (chart visuals only; the BRIDGE owns real position state) ===
var bool isLong  = false
var bool isShort = false
LONG  = not isLong  and pos == 1
SHORT = not isShort and pos == -1
if LONG
    isLong  := true
    isShort := false
if SHORT
    isLong  := false
    isShort := true

// === VISUALS ===
vwmaOut = ta.vwma(src, smoothLen)
avg1    = math.avg(vwmaOut, xATRTrailingStop)
plot(avg1, color=color.aqua, title="ATR avg")
vol_avg = ta.sma(volume, vol_length)
unusual_vol_up   = volume > vol_avg * 1.2 and close > open
unusual_vol_down = volume > vol_avg * 1.2 and close < open
barcolor(unusual_vol_up or unusual_vol_down ? color.yellow : na)
plotshape(LONG,  title="Buy",  style=shape.labelup,  location=location.belowbar, text="Buy",  textcolor=color.white, color=color.green)
plotshape(SHORT, title="Sell", style=shape.labeldown, location=location.abovebar, text="Sell", textcolor=color.white, color=color.red)

// === ALERTS (bar close only) ===
// Only the BUY is sent to the bridge — exits come from the separate exit
// indicator. SHORT is left as a chart marker (long-only strategy).
if LONG and barstate.isconfirmed
    alert('{"action":"buy","symbol":"' + syminfo.ticker + '","secret":"' + webhookSecret + '"}', alert.freq_once_per_bar_close)
